<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Resume Tailor — Pathfinder</title>
  <link rel="stylesheet" href="../shared/pathfinder.css">
  <style>
    /* ====== Resume Tailor Module Styles ====== */
    .resume-tailor-container {
      display: flex;
      flex-direction: column;
      gap: var(--space-6);
      padding: var(--space-6);
      padding-top: calc(var(--nav-height) + var(--space-6));
      max-width: 1200px;
      margin: 0 auto;
    }

    .phase-header {
      display: flex;
      align-items: center;
      gap: var(--space-4);
      margin-bottom: var(--space-4);
      padding-bottom: var(--space-4);
      border-bottom: 2px solid var(--bg-subtle);
    }

    .phase-badge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 32px;
      height: 32px;
      border-radius: 50%;
      background: var(--accent);
      color: white;
      font-weight: bold;
      font-size: 14px;
    }

    .phase-title {
      margin: 0;
      font-size: 18px;
      font-weight: 600;
      color: var(--text-primary);
    }

    .phase-section {
      background: var(--bg-surface);
      border: 1px solid var(--bg-subtle);
      border-radius: 8px;
      padding: var(--space-6);
      margin-bottom: var(--space-6);
    }

    .role-selector-wrapper {
      display: flex;
      gap: var(--space-4);
      align-items: flex-end;
      margin-bottom: var(--space-6);
    }

    .role-selector-wrapper select {
      flex: 1;
      padding: var(--space-2) var(--space-4);
      border: 1px solid var(--bg-subtle);
      border-radius: 6px;
      background: var(--bg-base);
      color: var(--text-primary);
      font-size: 14px;
      cursor: pointer;
    }

    .role-selector-wrapper select:focus {
      outline: none;
      border-color: var(--accent);
      box-shadow: 0 0 0 2px rgba(99, 102, 241, 0.1);
    }

    .role-context-card {
      background: var(--bg-base);
      border: 1px solid var(--bg-subtle);
      border-radius: 8px;
      padding: var(--space-6);
      margin-bottom: var(--space-6);
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--space-6);
    }

    .role-context-card.full-width {
      grid-template-columns: 1fr;
    }

    .context-field {
      display: flex;
      flex-direction: column;
      gap: var(--space-1);
    }

    .context-label {
      font-size: 12px;
      font-weight: 600;
      color: var(--text-secondary);
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .context-value {
      font-size: 15px;
      color: var(--text-primary);
      word-break: break-word;
    }

    .jd-preview {
      background: var(--bg-surface);
      border-left: 3px solid var(--accent);
      padding: var(--space-4);
      border-radius: 4px;
      font-size: 13px;
      line-height: 1.6;
      max-height: 150px;
      overflow-y: auto;
      color: var(--text-secondary);
    }

    .keywords-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--space-6);
      margin-bottom: var(--space-6);
    }

    .keyword-group {
      display: flex;
      flex-direction: column;
      gap: var(--space-4);
    }

    .keyword-group-title {
      font-size: 14px;
      font-weight: 600;
      color: var(--text-primary);
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .keyword-tags {
      display: flex;
      flex-wrap: wrap;
      gap: var(--space-2);
    }

    .keyword-chip {
      display: inline-flex;
      align-items: center;
      gap: var(--space-1);
      padding: 6px 12px;
      border-radius: 20px;
      font-size: 12px;
      font-weight: 500;
      white-space: nowrap;
      border: 1px solid;
    }

    .keyword-chip.strong {
      background: #d4edda;
      border-color: #28a745;
      color: #155724;
    }

    .keyword-chip.borderline {
      background: #fff3cd;
      border-color: #ffc107;
      color: #856404;
    }

    .keyword-chip.gap {
      background: #f8d7da;
      border-color: #dc3545;
      color: #721c24;
    }

    .keyword-indicator {
      display: inline-block;
      font-size: 10px;
    }

    .bullets-list {
      display: flex;
      flex-direction: column;
      gap: var(--space-4);
      margin-bottom: var(--space-6);
    }

    .bullet-item {
      background: var(--bg-base);
      border: 1px solid var(--bg-subtle);
      border-radius: 6px;
      padding: var(--space-4);
      display: grid;
      grid-template-columns: 1fr auto auto auto;
      gap: var(--space-4);
      align-items: center;
    }

    .bullet-item.locked {
      border-color: var(--accent);
      background: rgba(99, 102, 241, 0.02);
    }

    .bullet-content {
      display: flex;
      flex-direction: column;
      gap: var(--space-1);
    }

    .bullet-text {
      flex: 1;
      padding: var(--space-2);
      border: 1px solid var(--bg-subtle);
      border-radius: 4px;
      background: var(--bg-surface);
      color: var(--text-primary);
      font-size: 14px;
      line-height: 1.5;
      font-family: inherit;
      resize: vertical;
      min-height: 50px;
    }

    .bullet-text:focus {
      outline: none;
      border-color: var(--accent);
      background: var(--bg-base);
    }

    .bullet-meta {
      display: flex;
      align-items: center;
      gap: var(--space-1);
      flex-wrap: wrap;
    }

    .bullet-source-badge {
      font-size: 11px;
      padding: 4px 8px;
      border-radius: 4px;
      font-weight: 500;
      background: var(--bg-surface);
      color: var(--text-secondary);
      border: 1px solid var(--bg-subtle);
    }

    .bullet-source-badge.ai-generated {
      background: rgba(76, 175, 80, 0.1);
      color: #2e7d32;
      border-color: rgba(76, 175, 80, 0.3);
    }

    .bullet-source-badge.bullet-bank {
      background: rgba(33, 150, 243, 0.1);
      color: #1565c0;
      border-color: rgba(33, 150, 243, 0.3);
    }

    .bullet-source-badge.manual {
      background: rgba(156, 39, 176, 0.1);
      color: #6a1b9a;
      border-color: rgba(156, 39, 176, 0.3);
    }

    .bullet-actions {
      display: flex;
      gap: var(--space-1);
      align-items: center;
    }

    .bullet-lock-btn {
      background: none;
      border: none;
      padding: var(--space-1);
      cursor: pointer;
      font-size: 16px;
      color: var(--text-secondary);
      border-radius: 4px;
      transition: all 200ms ease;
      display: flex;
      align-items: center;
      justify-content: center;
      width: 32px;
      height: 32px;
    }

    .bullet-lock-btn:hover {
      background: var(--bg-surface);
      color: var(--accent);
    }

    .bullet-lock-btn.locked {
      color: var(--accent);
    }

    .bullet-delete-btn {
      background: none;
      border: none;
      padding: var(--space-1);
      cursor: pointer;
      font-size: 16px;
      color: var(--text-secondary);
      border-radius: 4px;
      transition: all 200ms ease;
      display: flex;
      align-items: center;
      justify-content: center;
      width: 32px;
      height: 32px;
    }

    .bullet-delete-btn:hover {
      background: #f8d7da;
      color: #dc3545;
    }

    .button-group {
      display: flex;
      gap: var(--space-4);
      flex-wrap: wrap;
      margin-bottom: var(--space-6);
    }

    .btn-primary,
    .btn-secondary {
      padding: var(--space-2) var(--space-4);
      border: none;
      border-radius: 6px;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      transition: all 200ms ease;
      display: inline-flex;
      align-items: center;
      gap: var(--space-1);
    }

    .btn-primary {
      background: var(--accent);
      color: white;
    }

    .btn-primary:hover {
      background: var(--accent);
      transform: translateY(-1px);
      box-shadow: 0 2px 8px rgba(99, 102, 241, 0.3);
    }

    .btn-secondary {
      background: var(--bg-surface);
      color: var(--text-primary);
      border: 1px solid var(--bg-subtle);
    }

    .btn-secondary:hover {
      background: var(--bg-subtle);
    }

    .btn-small {
      padding: var(--space-1) var(--space-2);
      font-size: 12px;
    }

    .manual-keywords-form {
      display: flex;
      flex-direction: column;
      gap: var(--space-4);
      background: var(--bg-base);
      padding: var(--space-6);
      border-radius: 8px;
      border: 1px dashed var(--bg-subtle);
    }

    .form-group {
      display: flex;
      flex-direction: column;
      gap: var(--space-1);
    }

    .form-label {
      font-size: 13px;
      font-weight: 600;
      color: var(--text-primary);
    }

    .form-input {
      padding: var(--space-2) var(--space-4);
      border: 1px solid var(--bg-subtle);
      border-radius: 6px;
      background: var(--bg-surface);
      color: var(--text-primary);
      font-size: 14px;
      font-family: inherit;
    }

    .form-input:focus {
      outline: none;
      border-color: var(--accent);
      background: var(--bg-base);
    }

    .form-input.textarea {
      min-height: 100px;
      resize: vertical;
    }

    .tabs {
      display: flex;
      gap: var(--space-4);
      border-bottom: 2px solid var(--bg-subtle);
      margin-bottom: var(--space-6);
    }

    .tab-button {
      padding: var(--space-4) var(--space-6);
      background: none;
      border: none;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      color: var(--text-secondary);
      border-bottom: 2px solid transparent;
      margin-bottom: -2px;
      transition: all 200ms ease;
    }

    .tab-button.active {
      color: var(--accent);
      border-bottom-color: var(--accent);
    }

    .tab-button:hover {
      color: var(--text-primary);
    }

    .tab-content {
      display: none;
    }

    .tab-content.active {
      display: block;
    }

    .version-item {
      background: var(--bg-base);
      border: 1px solid var(--bg-subtle);
      border-radius: 6px;
      padding: var(--space-4);
      display: grid;
      grid-template-columns: 1fr auto;
      gap: var(--space-4);
      align-items: center;
      margin-bottom: var(--space-2);
    }

    .version-info {
      display: flex;
      flex-direction: column;
      gap: var(--space-1);
    }

    .version-title {
      font-weight: 600;
      color: var(--text-primary);
      font-size: 14px;
    }

    .version-meta {
      font-size: 12px;
      color: var(--text-secondary);
    }

    .version-actions {
      display: flex;
      gap: var(--space-1);
    }

    .version-actions button {
      padding: 6px 12px;
      border: none;
      border-radius: 4px;
      font-size: 12px;
      font-weight: 600;
      cursor: pointer;
      transition: all 200ms ease;
    }

    .btn-load {
      background: var(--accent);
      color: white;
    }

    .btn-load:hover {
      background: var(--accent);
    }

    .btn-delete {
      background: #f8d7da;
      color: #dc3545;
      border: 1px solid #dc3545;
    }

    .btn-delete:hover {
      background: #dc3545;
      color: white;
    }

    .empty-state {
      text-align: center;
      padding: var(--space-8);
      color: var(--text-secondary);
    }

    .empty-state-icon {
      font-size: 48px;
      margin-bottom: var(--space-4);
    }

    .empty-state-title {
      font-size: 18px;
      font-weight: 600;
      color: var(--text-primary);
      margin-bottom: var(--space-2);
    }

    .empty-state-message {
      font-size: 14px;
      margin-bottom: var(--space-6);
    }

    .loading-skeleton {
      background: linear-gradient(90deg, var(--bg-subtle) 0%, var(--bg-surface) 50%, var(--bg-subtle) 100%);
      background-size: 200% 100%;
      animation: loading 1.5s infinite;
    }

    @keyframes loading {
      0% {
        background-position: 200% 0;
      }
      100% {
        background-position: -200% 0;
      }
    }

    @media (max-width: 768px) {
      .role-context-card,
      .keywords-grid {
        grid-template-columns: 1fr;
      }

      .bullet-item {
        grid-template-columns: 1fr;
      }

      .button-group {
        flex-direction: column;
      }

      .btn-primary,
      .btn-secondary {
        width: 100%;
        justify-content: center;
      }
    }
  </style>
</head>
<body>
  <div id="nav-container"></div>

  <main class="resume-tailor-container">
    <div id="resume-tailor-content"></div>
  </main>

  <script src="../shared/data-layer.js?v=5.0.0"></script>
  <script src="../shared/components.js"></script>
  <script src="../shared/dedup-utils.js"></script>
  <script src="../shared/api-client.js"></script>
  <script src="../shared/privacy-indicator.js"></script>
  <script src="../shared/backup-utils.js"></script>
  <script src="./resume-tailor.js"></script>
</body>
</html>
